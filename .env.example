# Code Cloud Agents - Environment Variables

# ═══════════════════════════════════════════════════════════════
# ANTHROPIC API
# ═══════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ═══════════════════════════════════════════════════════════════
# AIDER CONFIG
# ═══════════════════════════════════════════════════════════════
AIDER_MODEL=claude-sonnet-4
AIDER_AUTO_COMMITS=true

# ═══════════════════════════════════════════════════════════════
# GITHUB (für lokale Entwicklung, in Actions automatisch gesetzt)
# ═══════════════════════════════════════════════════════════════
GITHUB_TOKEN=ghp_your_token_here

# ═══════════════════════════════════════════════════════════════
# APP CONFIG
# ═══════════════════════════════════════════════════════════════
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# ═══════════════════════════════════════════════════════════════
# DATABASE (Phase 2)
# ═══════════════════════════════════════════════════════════════
# DATABASE_URL=postgresql://user:pass@localhost:5432/code_cloud_agents

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: NOTIFICATIONS (Phase 2)
# ═══════════════════════════════════════════════════════════════
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
