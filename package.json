{
  "name": "my-app",
  "version": "1.0.0",
  "description": "Express application with Redis support",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "start:api": "node src/api-server.js",
    "web": "node dist/web/server.js",
    "dev:web": "tsc -p tsconfig.json && node dist/web/server.js",
    "dev": "tsx watch src/index.ts",
    "dev:api": "node --watch src/api-server.js",
    "test": "jest",
    "test:unit": "jest tests/example.test.js",
    "test:integration": "jest tests/integration.test.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "tsc",
    "chat": "node dist/chat/cli.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@types/node": "^25.0.10",
    "axios": "^1.13.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "hono": "^4.7.0",
    "ioredis": "^5.3.2",
    "json2csv": "^6.0.0-alpha.2",
    "rate-limit-redis": "^4.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "winston": "^3.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/json2csv": "^5.0.7",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/den-is9186/code-cloud-agents.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/den-is9186/code-cloud-agents/issues"
  },
  "homepage": "https://github.com/den-is9186/code-cloud-agents#readme"
}
