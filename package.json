{
  "name": "my-app",
  "version": "1.0.0",
  "description": "Express application with Redis support",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "jest",
    "test:unit": "jest tests/example.test.js",
    "test:integration": "jest tests/integration.test.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/node": "^25.0.10",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/den-is9186/code-cloud-agents.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/den-is9186/code-cloud-agents/issues"
  },
  "homepage": "https://github.com/den-is9186/code-cloud-agents#readme"
}
