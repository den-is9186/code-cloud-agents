# ═══════════════════════════════════════════════════════════════
# CODE CLOUD AGENTS - ENVIRONMENT CONFIG
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# API PROVIDERS
# ─────────────────────────────────────────────────────────────────

# Novita AI (für DeepSeek Modelle)
NOVITA_API_KEY=your_novita_key_here
NOVITA_BASE_URL=https://api.novita.ai/v3/openai

# Anthropic (für Claude Modelle)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenRouter (Alternative/Fallback)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─────────────────────────────────────────────────────────────────
# LOCAL LLM SERVER (für Scout)
# ─────────────────────────────────────────────────────────────────

# Endpoint eures lokalen Llama 4 Scout Servers
# Beispiele:
#   vLLM:      http://server:8000
#   Ollama:    http://server:11434
#   llama.cpp: http://server:8080
LOCAL_LLM_ENDPOINT=http://localhost:8000

# Optional: Auth für lokalen Server
# LOCAL_LLM_API_KEY=optional_local_key

# ─────────────────────────────────────────────────────────────────
# DEFAULT PRESET
# ─────────────────────────────────────────────────────────────────

# Welches Preset standardmäßig verwenden?
# Options: A, B, B+, C, D, V, L, LOCAL, E, F
DEFAULT_PRESET=LOCAL

# ─────────────────────────────────────────────────────────────────
# AGENT CONFIG
# ─────────────────────────────────────────────────────────────────

# Max Iterationen bevor Abbruch
MAX_ITERATIONS=10

# Max Retries bei API-Fehlern
MAX_RETRIES=3

# Timeout pro Agent-Call (Sekunden)
AGENT_TIMEOUT=120

# ─────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────

# Log Level: debug, info, warn, error
LOG_LEVEL=info

# Log API calls (Kosten-Tracking)
LOG_API_CALLS=true

# ─────────────────────────────────────────────────────────────────
# PATHS
# ─────────────────────────────────────────────────────────────────

# Wo sollen generierte Files gespeichert werden?
OUTPUT_DIR=./output

# Wo sind die Projekt-Dateien?
PROJECT_ROOT=./
