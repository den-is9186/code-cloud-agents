echo "🧪 Running pre-push checks..."

# Get current branch
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Tests
echo "🧪 Running tests..."

# Strict mode for main/develop branches
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "develop" ]; then
  echo "ℹ️  On protected branch '$BRANCH' - tests must pass"
  npm test || exit 1
else
  # Non-blocking for feature branches - run all tests
  echo "🧪 Running tests on branch '$BRANCH'..."
  if ! npm test; then
    echo "⚠️  Tests failed, but allowing push to continue on branch '$BRANCH'"
    echo "ℹ️  Please fix tests before merging to main/develop"
    exit 0
  fi
fi

echo "✅ Pre-push checks passed!"
